# Swarmit SPA — deployment configuration
# These values are baked into the bundle at build time by Vite.
# Override locally via .env.local (gitignored).

# Chain
VITE_CHAIN_ID=100
VITE_RPC_URL=https://rpc.gnosischain.com

# SwarmitRegistryV3 contract
VITE_CONTRACT_ADDRESS=0xf759cD44a0d477E4e593468993ffbD935FD838bc
VITE_CONTRACT_DEPLOY_BLOCK=45658410

# Default curators (comma-separated bzz:// profile feed refs)
VITE_DEFAULT_CURATORS=bzz://311a2ee72423944f3222a6b63277c55aab8d91c9be924a2c9fddb4c46a53cb72

# SwarmitUsernameRegistry contract (optional — leave empty to disable)
VITE_USERNAME_REGISTRY_ADDRESS=0xc59537C0665b46ED915456D1F45C44973EbB1426
VITE_USERNAME_REGISTRY_DEPLOY_BLOCK=45605238

# Multicall3 (canonical address on Gnosis and most EVM chains)
VITE_MULTICALL3_ADDRESS=0xcA11bde05977b3631167028862bE2a173976CA11
